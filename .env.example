# Copy to .env and fill in. .env is gitignored.
#
# Default backend is Gemini (free tier — no credit card).
# Get a key in 30 seconds at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: use Claude instead. Set LLM_PROVIDER=anthropic to force it.
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_PROVIDER=anthropic

# Optional model overrides. Defaults track the chosen provider:
#   - gemini      → gemini-2.5-flash for both
#   - anthropic   → claude-sonnet-4-6 (classifier) + claude-opus-4-7 (synthesizer)
# CLASSIFIER_MODEL=gemini-2.5-flash
# SYNTHESIZER_MODEL=gemini-2.5-flash
